{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "plugin": [".opencode/plugins/write-size-guard.ts"],
  "mcp": {
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git@0.1.2", "--repository", "."],
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": ["gh", "mcp"],
      "enabled": true
    }
  },
  "agent": {
    "python-engineer": {
      "description": "Implements small, well-tested Python changes using uv, ruff, ty, and pytest.",
      "mode": "subagent"
    },
    "explore": {
      "description": "Explores codebase structure, finds relevant files, and provides context for implementation tasks",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "scout": {
      "description": "Read-only agent for external docs, dependency research, and codebase reconnaissance",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "multimodal": {
      "description": "Analyzes images, videos, and audio files — use when the current model lacks multimodal capabilities",
      "mode": "subagent",
      "model": "mimo/mimo-v2.5"
    }
  },
  "command": {
    "check": {
      "description": "Run format, lint, type, test, and build checks",
      "template": "Run the project checks and report failures clearly: `uv run ruff format --check`, `uv run ruff check`, `uv run ty check`, `uv run pytest`, and `uv build`."
    },
    "grill-me": {
      "description": "Stress-test a plan or design",
      "template": "Use the grill-me skill to stress-test this plan or design: $ARGUMENTS"
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "uv run *": "allow",
      "uv sync *": "allow",
      "uv build *": "allow",
      "git status": "allow",
      "git fetch *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "git branch --show-current": "allow",
      "git branch -a": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "pwd": "allow",
      "tree *": "allow",
      "file *": "allow",
      "which *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "echo *": "allow",
      "gh auth status": "allow",
      "gh issue view *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "gh issue list *": "allow",
      "git push *": "allow",
      "gh pr create *": "allow",
      "git checkout *": "allow",
      
      "git remote *": "ask",
      "gh pr merge *": "ask",
      "gh pr close *": "ask",
      "gh issue create *": "ask",
      "gh issue close *": "ask",
      "gh issue edit *": "ask",
      "rm *": "ask",
      "rmdir *": "ask",
      "git worktree *": "allow",

      "gh repo *": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "sudo *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "git reset *": "deny",
      "git rebase *": "deny",
      "git clean *": "deny",
      "git stash *": "deny",
      "git branch -d *": "deny",
      "git branch -D *": "deny"
    },
    "skill": "allow"
  },
  "share": "disabled"
}
